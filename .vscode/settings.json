{
  // 🎨 Tema VS Code adaptado a la paleta moderna de NestJS
  "workbench.colorCustomizations": {
    // Barra lateral izquierda (explorador, extensiones, etc.)
    "activityBar.background": "#E0234E",
    "activityBar.foreground": "#FFFFFF",
    "activityBar.inactiveForeground": "#FFFFFFCC",
    "activityBar.activeBackground": "#B81C41",
    "activityBar.activeBorder": "#FFFFFF",
    "activityBarBadge.background": "#FFFFFF",
    "activityBarBadge.foreground": "#E0234E",

    // Barra superior (título)
    "titleBar.activeBackground": "#E0234E",
    "titleBar.activeForeground": "#FFFFFF",
    "titleBar.inactiveBackground": "#B81C41",
    "titleBar.inactiveForeground": "#FFFFFFCC",

    // Barra inferior (status bar)
    "statusBar.background": "#E0234E",
    "statusBar.foreground": "#FFFFFF",
    "statusBarItem.hoverBackground": "#B81C41",
    "statusBarItem.remoteBackground": "#E0234E",
    "statusBarItem.remoteForeground": "#FFFFFF",

    // Minimapa, bordes y elementos activos
    "focusBorder": "#FFFFFF80",
    "commandCenter.border": "#FFFFFF55",
    "sash.hoverBorder": "#FFFFFF88"
  },

  // peacock extension
  "peacock.color": "#E0234E"
}
